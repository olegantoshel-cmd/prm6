_dish():\n","    \"\"\"Добавление блюда в меню\"\"\"\n","    print(\"\\n--- Добавление блюда ---\")\n","    name = input(\"Название: \")\n","    price = float(input(\"Цена: \"))\n","    category = input(\"Категория (горячее/холодное/напитки): \")\n","    time = int(input(\"Время приготовления (мин): \"))\n","\n","    dish = {\n","        \"название\": name,\n","        \"цена\": price,\n","        \"категория\": category,\n","        \"время\": time,\n","        \"популярность\": 0\n","    }\n","    menu.append(dish)\n","    print(f\"✅ Блюдо '{name}' добавлено!\")\n","\n","def create_order():\n","    \"\"\"Создание заказа\"\"\"\n","    print(\"\\n--- Новый заказ ---\")\n","\n","    # Показываем меню\n","    print(\"\\nМеню:\")\n","    for i, dish in enumerate(menu):\n","        print(f\"{i+1}. {dish['название']} - {dish['цена']} руб.\")\n","\n","    # Выбор блюд\n","    table = input(\"Номер стола: \")\n","    dishes = input(\"Номера блюд через пробел: \").split()\n","\n","    # Собираем заказ\n","    order_dishes = []\n","    total = 0\n","    for num in dishes:\n","        idx = int(num) - 1\n","        if 0 <= idx < len(menu):\n","            dish = menu[idx]\n","            order_dishes.append(dish)\n","            total += dish[\"цена\"]\n","            dish[\"популярность\"] += 1\n","\n","    order = {\n","        \"стол\": table,\n","        \"блюда\": order_dishes,\n","        \"сумма\": total,\n","        \"статус\": \"готовится\"\n","    }\n","    orders.append(order)\n","    print(f\"✅ Заказ принят! Сумма: {total} руб.\")\n","\n","def popular_dishes():\n","    \"\"\"Топ популярных блюд\"\"\"\n","    print(\"\\n--- Популярные блюда ---\")\n","    # Сортируем по популярности\n","    sorted_menu = sorted(menu, key=lambda x: x[\"популярность\"], reverse=True)\n","\n","    for i, dish in enumerate(sorted_menu[:3], 1):\n","        print(f\"{i}. {dish['название']} - {dish['популярность']} заказов\")\n","\n","def revenue_stats():\n","    \"\"\"Выручка по категориям\"\"\"\n","    print(\"\\n--- Выручка по категориям ---\")\n","\n","    stats = {}\n","    for order in orders:\n","        for dish in order[\"блюда\"]:\n","            cat = dish[\"категория\"]\n","            if cat in stats:\n","                stats[cat] += dish[\"цена\"]\n","            else:\n","                stats[cat] = dish[\"цена\"]\n","\n","    for cat in stats:\n","        print(f\"{cat}: {stats[cat]} руб.\")\n","\n","# Тестирование\n","print(\"=== СИСТЕМА ЗАКАЗОВ КАФЕ ===\")\n","\n","# Добавляем блюда\n","add_dish()  # Добавьте: Пицца, 500, горячее, 15\n","add_dish()  # Добавьте: Салат, 300, холодное, 10\n","add_dish()  # Добавьте: Чай, 100, напитки, 5\n","\n","# Создаем заказы\n","create_order()\n","create_order()\n","\n","# Статистика\n","popular_dishes()\n","revenue_stats()\n","\n","print(f\"\\nВсего блюд в меню: {len(menu)}\")\n","print(f\"Всего заказов: {len(orders)}\")"]},{"cell_type":"code","source":["# Простая система учета успеваемости\n","\n","# Хранилища данных\n","students = []  # список студентов\n","grades = []    # список оценок\n","\n","def add_student():\n","    \"\"\"Добавление студента\"\"\"\n","    print(\"\\n--- Добавление студента ---\")\n","    name = input(\"ФИО: \")\n","    group = input(\"Группа: \")\n","\n","    student = {\n","        \"id\": len(students) + 1,\n","        \"фио\": name,\n","        \"группа\": group,\n","        \"контакты\": input(\"Телефон: \")\n","    }\n","    students.append(student)\n","    print(f\"✅ Студент {name} добавлен (ID: {student['id']})\")\n","\n","def add_grade():\n","    \"\"\"Добавление оценки\"\"\"\n","    print(\"\\n--- Добавление оценки ---\")\n","\n","    # Показываем студентов\n","    for s in students:\n","        print(f\"{s['id']}. {s['фио']} ({s['группа']})\")\n","\n","    student_id = int(input(\"ID студента: \"))\n","    subject = input(\"Предмет: \")\n","    grade = int(input(\"Оценка (2-5): \"))\n","\n","    grade_record = {\n","        \"студент_id\": student_id,\n","        \"предмет\": subject,\n","        \"оценка\": grade,\n","        \"дата\": input(\"Дата (ГГГГ-ММ-ДД): \")\n","    }\n","    grades.append(grade_record)\n","    print(\"✅ Оценка добавлена!\")\n","\n","def student_avg(student_id):\n","    \"\"\"Средний балл студента\"\"\"\n","    student_grades = [g[\"оценка\"] for g in grades if g[\"студент_id\"] == student_id]\n","    if student_grades:\n","        return sum(student_grades) / len(student_grades)\n","    return 0\n","\n","def find_bad_students(threshold=3):\n","    \"\"\"Поиск студентов с низкими оценками\"\"\"\n","    print(f\"\\n--- Студенты с оценками ниже {threshold} ---\")\n","\n","    bad_students = set()\n","    for g in grades:\n","        if g[\"оценка\"] < threshold:\n","            bad_students.add(g[\"студент_id\"])\n","\n","    for student in students:\n","        if student[\"id\"] in bad_students:\n","            avg = student_avg(student[\"id\"])\n","            print(f\"❌ {student['фио']} (ср.балл: {avg:.2f})\")\n","\n","def student_rating():\n","    \"\"\"Рейтинг студентов\"\"\"\n","    print(\"\\n--- Рейтинг студентов ---\")\n","\n","    rating = []\n","    for student in students:\n","        avg = student_avg(student[\"id\"])\n","        rating.append({\n","            \"фио\": student[\"фио\"],\n","            \"группа\": student[\"группа\"],\n","            \"средний_балл\": avg\n","        })\n","\n","    # Сортируем по убыванию среднего балла\n","    rating.sort(key=lambda x: x[\"средний_балл\"], reverse=True)\n","\n","    for i, s in enumerate(rating, 1):\n","        print(f\"{i}. {s['фио']} ({s['группа']}) - {s['средний_балл']:.2f}\")\n","\n","# Тестирование\n","print(\"=== УЧЕТ УСПЕВАЕМОСТИ СТУДЕНТОВ ===\")\n","\n","# Добавляем студентов\n","add_student()  # Иванов И.И., ИС-21\n","add_student()  # Петров П.П., ИС-21\n","add_student()  # Сидорова С.С., ИС-21\n","\n","# Добавляем оценки\n","add_grade()    # Оценки для Иванова\n","add_grade()    # Оценки для Петрова\n","add_grade()    #